---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => 
  new Date(b.data.datetime).getTime() - new Date(a.data.datetime).getTime()
);
const recentPosts = sortedPosts.slice(0, 5);

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  return `${date.getDate()} ${months[date.getMonth()]}, ${date.getFullYear()}`;
}

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Markus Dröws",
  "url": Astro.site,
  "jobTitle": "Cyberanalyst, OSINT Specialist",
  "description": "Cyberanalyst, OSINT Specialist, and Software Developer",
  "sameAs": [
    "https://github.com/trabigator",
    "https://www.linkedin.com/in/markus-d140821"
  ],
  "knowsAbout": ["OSINT", "Cyber Analysis", "Software Development", "Law Enforcement Technology"]
};
---

<BaseLayout
  title="Markus Dröws"
  description="Markus Dröws - Cyberanalyst, OSINT Specialist, Software Developer"
  canonicalUrl={`${Astro.site}`}
  jsonLd={personJsonLd}
>
  <Header active="home" />

  <section id="hero">
    <div class="hero-content">
      <a href="/about/" class="avatar-link">
        <img src="/avatar.jpeg" alt="Markus Dröws" class="avatar" width="170" height="170" loading="lazy">
      </a>
      <div class="hero-text">
        <div class="title-row">
          <h1>Hi, I'm Markus</h1>
          <a target="_blank" href="/rss.xml" class="rss-link" aria-label="rss feed" title="RSS Feed">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="5" cy="19" r="1"></circle>
              <path d="M4 4a16 16 0 0 1 16 16"></path>
              <path d="M4 11a9 9 0 0 1 9 9"></path>
            </svg>
          </a>
        </div>
        <p>
          Cyberanalyst, OSINT Specialist, Software Developer
        </p>
        <div class="social-links">
          <a target="_blank" href="https://github.com/trabigator" class="social-link" title="GitHub">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-4 1.5-4-2-6-3"/>
              <path d="M15 21v-3.5c0-1 .1-1.5-.5-2 3-.35 5.5-1.5 5.5-6 0-1.2-.4-2.3-1.2-3.2.1-.3.5-1.6-.1-3.3 0 0-1.1-.3-3.5 1.3a11.8 11.8 0 0 0-6.4 0 C6.4 2.4 5.3 2.7 5.3 2.7c-.6 1.7-.2 3 .1 3.3 A4.6 4.6 0 0 0 4 9.5c0 4.5 2.5 5.6 5.5 6 -.6.5-.6 1.2-.5 2V21"/>
            </svg>
          </a>
          <a target="_blank" href="https://www.linkedin.com/in/markus-d140821" class="social-link" title="LinkedIn">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="4"/>
              <path d="M8 11v5"/>
              <path d="M8 8v.01"/>
              <path d="M12 16v-5"/>
              <path d="M16 16v-3a2 2 0 0 0-4 0"/>
            </svg>
          </a>
          <a href="mailto:markusword.de@proton.me" class="social-link" title="Email">
            <svg width="28" height="18" viewBox="0 0 30 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="24" height="18" rx="2"></rect>
              <path d="M3 8l12 8 12-8"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <section id="recent-posts">
    <ul>
      {recentPosts.map(post => {
        const urlParts = post.id.split('/');
        const year = urlParts[0];
        const month = urlParts[1];
        const slug = urlParts.slice(2).join('/');
        return (
          <li>
            <div class="post-item">
              <a href={`/post/${year}/${month}/${slug}`} class="post-link">
                <h3>{post.data.headline}</h3>
              </a>
              <div class="post-meta">
                <span class="date">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="7" width="16" height="14" rx="2"></rect>
                    <path d="M16 3v4"></path>
                    <path d="M8 3v4"></path>
                    <path d="M4 11h16"></path>
                  </svg>
                  <time datetime={post.data.datetime}>{formatDate(post.data.date)}</time>
                </span>
                <span class="read-time">- {post.data.readTime}</span>
              </div>
              <p>{post.data.teaser}</p>
            </div>
          </li>
        );
      })}
    </ul>
  </section>

  <div class="all-posts-link">
    <a href="/posts/">
      All Posts
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"></path>
        <path d="M13 18l6 -6"></path>
        <path d="M13 6l6 6"></path>
      </svg>
    </a>
  </div>

  <Footer />
</BaseLayout>

<style>
  #hero {
    padding-top: 24px;
    padding-bottom: 16px;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }

  @media (min-width: 640px) {
    .hero-content {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .avatar-link {
    display: block;
    margin: 0 auto;
  }

  .avatar {
    width: 170px;
    height: 170px;
    border-radius: 50%;
    object-fit: cover;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    transform: scale(1);
  }

  .avatar-link:hover .avatar {
    transform: scale(1.05);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
  }

  .hero-text {
    flex: 1;
    text-align: center;
  }

  @media (min-width: 640px) {
    .hero-text {
      text-align: left;
      padding-left: 16px;
    }
  }

  .title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  @media (min-width: 640px) {
    .title-row {
      justify-content: flex-start;
    }
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 8px 0;
  }

  @media (min-width: 640px) {
    h1 {
      font-size: 1.875rem;
      margin: 16px 0;
    }
  }

  .rss-link svg {
    stroke: var(--accent);
    stroke-width: 3;
    transform: scale(1.25);
  }

  .hero-text p {
    opacity: 0.8;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-top: 16px;
    flex-wrap: wrap;
  }

  @media (min-width: 640px) {
    .social-links {
      justify-content: flex-start;
    }
  }

  .social-link {
    display: inline-block;
    padding: 8px;
    transition: transform 0.2s, color 0.2s;
    color: inherit;
  }

  .social-link:hover {
    color: var(--accent);
    transform: rotate(6deg);
  }

  .social-link svg {
    display: inline-block;
    width: 24px;
    height: 24px;
    transform: scale(1.25);
    opacity: 0.9;
  }

  #recent-posts {
    padding-top: 48px;
    padding-bottom: 24px;
  }

  #recent-posts ul li {
    margin: 32px 0;
  }

  .post-item h3 {
    font-size: 1.125rem;
    font-weight: 500;
    text-decoration: dashed;
    text-underline-offset: 4px;
  }

  .post-link {
    display: inline-block;
    color: var(--accent);
    text-decoration: dashed;
  }

  .post-link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .post-meta .date {
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0.8;
  }

  .post-meta svg {
    display: inline-block;
    width: 20px;
    height: 20px;
    min-width: 20px;
  }

  .post-meta time {
    font-size: 0.875rem;
    font-style: italic;
  }

  .read-time {
    font-size: 0.875rem;
    font-style: italic;
    opacity: 0.8;
  }

  .post-item > p {
    opacity: 0.8;
    flex: 1;
  }

  .all-posts-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin: 32px 0;
  }

  .all-posts-link a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: inherit;
    transition: color 0.2s;
  }

  .all-posts-link a:hover {
    color: var(--accent);
  }

  .divider {
    max-width: 860px;
    margin: 0 auto;
    border: 0;
    border-top: 1px solid var(--border);
  }
</style>
